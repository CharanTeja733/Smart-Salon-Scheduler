# ============ DATABASE ============
DATABASE_URL=postgresql://salon_user:salon_password@postgres:5432/salon_scheduler
# Or for local development without Docker:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/salon_scheduler

# ============ REDIS (Celery Broker) ============
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ============ EXTERNAL API KEYS ============
GOOGLE_PLACES_API_KEY=AIzaSy... (your key)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890
RESEND_API_KEY=re_...

# ============ ENVIRONMENT ============
ENVIRONMENT=development   # or staging, production
DEBUG=True                # Enable/disable debug mode
SECRET_KEY=some-random-secret-for-sessions (if you add auth later)

# ============ OPTIONAL OVERRIDES ============
# Override default API limits (if needed)
RATE_LIMIT_REQUESTS_PER_MINUTE=100
BOOKING_MIN_ADVANCE_HOURS=1
BOOKING_MAX_ADVANCE_DAYS=90